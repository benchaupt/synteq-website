{
    "name": "synteq-enterprise",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
        "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
        "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
        "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
        "start": "next start",
        "lint": "eslint",
        "generate:types": "payload generate:types",
        "job-sync:dev": "wrangler dev --config workers/job-sync/wrangler.toml",
        "job-sync:deploy": "wrangler deploy --config workers/job-sync/wrangler.toml",
        "job-sync:tail": "wrangler tail synteq-job-sync",
        "proxy": "frpc http -n synteq-development-lusory -l 3000 -i 127.0.0.1 --uc --ue --sd synteq-development-lusory -s server.kitten.es -P 7000 --tls-enable --token \"$(cat ~/.config/kitten.es/token)\""
    },
    "dependencies": {
        "@base-ui/react": "^1.0.0",
        "@opennextjs/cloudflare": "^1.16.2",
        "@payloadcms/admin-bar": "^3.69.0",
        "@payloadcms/db-postgres": "^3.69.0",
        "@payloadcms/live-preview-react": "^3.69.0",
        "@payloadcms/next": "^3.69.0",
        "@payloadcms/plugin-redirects": "^3.69.0",
        "@payloadcms/plugin-seo": "^3.69.0",
        "@payloadcms/richtext-lexical": "^3.69.0",
        "@payloadcms/storage-r2": "^3.69.0",
        "@payloadcms/storage-s3": "^3.69.0",
        "@payloadcms/ui": "^3.69.0",
        "@radix-ui/react-accordion": "^1.2.12",
        "@radix-ui/react-navigation-menu": "^1.2.14",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-slot": "^1.2.4",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "embla-carousel-react": "^8.6.0",
        "graphql": "^16.12.0",
        "lenis": "^1.3.17",
        "lucide-react": "^0.562.0",
        "motion": "^12.23.26",
        "next": "15.4.11",
        "payload": "^3.69.0",
        "pg-cloudflare": "^1.2.7",
        "posthog-js": "^1.336.4",
        "prism-react-renderer": "^2.4.1",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "sharp": "^0.34.5",
        "tailwind-merge": "^3.4.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@tailwindcss/typography": "^0.5.19",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "16.1.0",
        "tailwindcss": "^4",
        "tsx": "^4.21.0",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5",
        "wrangler": "^4.61.1"
    }
}